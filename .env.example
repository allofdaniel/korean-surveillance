# ─────────────────────────────────────────────────────────────
# CLIENT-SIDE (VITE_ prefix — bundled into browser JS by Vite)
# These are safe to expose because they are domain/referrer restricted
# on their respective portals (Mapbox, GCP, V-World).
# ─────────────────────────────────────────────────────────────

# Mapbox public access token — restrict origins in Mapbox console
# https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Google Maps API key — restrict HTTP referrers in GCP console
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# V-World WMTS raster tile key — register allowed domains in V-World portal
# https://www.vworld.kr/dev/v4dv_tokenguide_s002.do
# NOTE: This key is exposed to the browser but is domain-restricted.
# TODO: remove once /api/vworld-tile proxy route is added.
VITE_VWORLD_API_KEY=your_vworld_api_key_here

# Observability: Vercel Speed Insights + Analytics
# 별도 가입/환경변수 필요 없음 — Vercel에 배포하면 자동 활성화됩니다.
# 코드 측 통합: src/main.tsx 의 <SpeedInsights /> + <Analytics />.
# 추가 RUM(예: Sentry)을 도입하려면 src/utils/logger.ts 의 sendToRemote() 에
# 직접 호출을 추가하세요.

# App Info
VITE_APP_NAME=대한감시
VITE_APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────────
# SERVER-ONLY (read by api/*.js via process.env)
# These are NOT referenced in any src/ frontend code.
# They must be added to the Vercel dashboard under Settings > Environment Variables.
# The VITE_ prefix in the name does NOT expose them to the browser —
# only import.meta.env references in src/ do that (which have been removed).
# ─────────────────────────────────────────────────────────────

# ITS 국가교통정보센터 CCTV API key
# Used by: api/cctv.js  |  Frontend proxy: /api/cctv?source=its
# Get key: https://www.its.go.kr/opendata/opendataList
VITE_ITS_API_KEY=your_its_api_key_here

# data.go.kr 공공데이터포털 API key
# Used by: api/cctv.js (Yeosu CCTV), api/ships.js
# Frontend proxies: /api/cctv?source=yeosu, /api/ships
# Get key: https://www.data.go.kr/
VITE_DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here

# aviationstack flight data API key
# Used by: api/flight-schedule.js
# Frontend proxy: /api/flight-schedule
# Get key: https://aviationstack.com/
VITE_AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
